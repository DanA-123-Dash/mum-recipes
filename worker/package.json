{
  "name": "mum-recipes-api",
  "private": true,
  "version": "0.1.0",
  "description": "Cloudflare Worker backing the shared cook log for mum-recipes PWA.",
  "scripts": {
    "dev": "wrangler dev --local --persist",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 execute mum_recipes_cook_log --file=migrations/0001_init.sql",
    "migrate:remote": "wrangler d1 execute mum_recipes_cook_log --file=migrations/0001_init.sql --remote",
    "tail": "wrangler tail"
  },
  "devDependencies": {
    "wrangler": "^3.80.0"
  }
}
